<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    InvoicesDetailDialog.xml - Invoice detail view
-->
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

    <GuiElement profile="fs25_dialogBg" id="dialogElement" size="900px 700px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>

        <GuiElement profile="fs25_dialogContentContainer">

            <BoxLayout profile="invDetMainBox">

                <!-- Title text (flows as first child) -->
                <Text profile="invDetMainTitle" text="$l10n_invoice_dialog_details" id="mainTitleText"/>

                <!-- Green gradient separator (flows as second child, centered dynamically) -->
                <GuiElement profile="invDetTitleSepWrapper">
                    <ThreePartBitmap profile="invDetTitleSep" id="titleSep"/>
                </GuiElement>

                <!-- Content area (flows as third child) -->
                <GuiElement profile="invDetContentArea">

                    <!-- Invoice number (left) + Status badge (right) -->
                    <Text profile="invDetInvNumber" id="textTitle"/>
                    <Text profile="invDetInvStatus" id="textStatus"/>

                    <!-- Separator after title row -->
                    <Bitmap profile="invDetSepTitle"/>

                    <!-- From (left) + Date (right) -->
                    <Text profile="invDetFrom" id="textFrom"/>
                    <Text profile="invDetDateVal" id="textDate"/>

                    <!-- To -->
                    <Text profile="invDetTo" id="textTo"/>

                    <!-- Separator before column headers -->
                    <Bitmap profile="invDetSepHeader"/>

                    <!-- Column headers: 7 columns -->
                    <Text profile="invDetColDesignation" text="$l10n_invoice_detail_col_service"/>
                    <Text profile="invDetColField"       text="$l10n_invoice_col_field"/>
                    <Text profile="invDetColQty"         text="$l10n_invoice_detail_col_qty"/>
                    <Text profile="invDetColUnit"        text="$l10n_invoice_detail_col_unit"/>
                    <Text profile="invDetColUnitPrice"   text="$l10n_invoice_detail_col_unitprice"/>
                    <Text profile="invDetColVat"         text="$l10n_invoice_step4_col_vat"/>
                    <Text profile="invDetColAmount"      text="$l10n_invoice_detail_col_amount"/>

                    <!-- Accent separator (green) below headers -->
                    <Bitmap profile="invDetSepAccent"/>

                    <!-- Line items SmoothList -->
                    <SmoothList profile="invDetList" id="listItems">
                        <ListItem profile="invDetListItem" name="templateItem">
                            <ThreePartBitmap profile="invDetGradient" name="alternating"/>
                            <Text profile="invDetCellDesignation" name="cellDesignation"/>
                            <Text profile="invDetCellField"       name="cellField"/>
                            <Text profile="invDetCellQty"         name="cellQty"/>
                            <Text profile="invDetCellUnit"        name="cellUnit"/>
                            <Text profile="invDetCellUnitPrice"   name="cellUnitPrice"/>
                            <Text profile="invDetCellVat"         name="cellVat"/>
                            <Text profile="invDetCellAmount"      name="cellAmount"/>
                        </ListItem>
                    </SmoothList>
                    <ThreePartBitmap profile="invDetSliderBox" id="sliderBox">
                        <Slider profile="fs25_listSlider" dataElementId="listItems"/>
                    </ThreePartBitmap>

                    <!-- Separator after list -->
                    <Bitmap profile="invDetSepBottom"/>

                    <!-- Notes section -->
                    <Text profile="invDetNotesLabel" text="$l10n_invoice_label_note"/>
                    <Text profile="invDetNotesValue" id="textNotes"/>

                    <!-- Separator before total -->
                    <Bitmap profile="invDetSepBeforeTotal"/>

                    <!-- Penalty bar (hidden by default, shown when overdue) -->
                    <RoundCorner profile="invDetPenaltyBarBg" id="penaltyBar"/>
                    <Text   profile="invDetPenaltyBarText" id="textPenaltyBar"/>

                    <!-- TOTAL bar -->
                    <RoundCorner profile="invDetTotalBarBg"/>
                    <Text   profile="invDetTotalLabel" text="$l10n_invoice_label_total" id="textTotalLabel"/>
                    <Text   profile="invDetVatHtText"  id="textVatHt"/>
                    <Text   profile="invDetVatTvaText" id="textVatTva"/>
                    <BoxLayout profile="invDetTotalSepBox">
                        <Bitmap profile="invDetTotalSepLine" id="totalSep"/>
                    </BoxLayout>
                    <Text   profile="invDetTotalValue" id="textTotal"/>

                </GuiElement>

            </BoxLayout>

        </GuiElement>

        <!-- Button bar (native Giant) -->
        <BoxLayout profile="fs25_dialogButtonBox" size="860px 60px">
            <Button profile="buttonOK" text="$l10n_invoice_btn_payInvoice" onClick="onClickPay" id="btnPay"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="buttonBack" text="$l10n_invoice_btn_close" onClick="onClickBack"/>
        </BoxLayout>
    </GuiElement>

    <GUIProfiles>
        <!-- Main content box (vertical flow, centered in content container) -->
        <Profile name="invDetMainBox" extends="emptyPanel" with="anchorTopCenter">
            <size value="832px 630px"/>
            <flowDirection value="vertical"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
            <elementSpacing value="0px"/>
        </Profile>

        <!-- Title text (BoxLayout child, no anchor needed) -->
        <Profile name="invDetMainTitle" extends="baseReference">
            <size value="832px 40px"/>
            <textSize value="18px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_fs25_colorMainLight"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Separator wrapper (BoxLayout child, bottom margin = gap before content) -->
        <Profile name="invDetTitleSepWrapper" extends="emptyPanel">
            <size value="832px 1px"/>
            <margin value="0px 0px 32px 0px"/>
        </Profile>

        <!-- Green gradient separator (centered, resized dynamically by Lua) -->
        <Profile name="invDetTitleSep" extends="fs25_lineSeparatorTopHighlighted" with="anchorTopCenter">
            <size value="200px 1px"/>
        </Profile>

        <!-- Content area (BoxLayout child) -->
        <Profile name="invDetContentArea" extends="emptyPanel">
            <size value="832px 557px"/>
        </Profile>

        <!-- Invoice number (left) + Status (right) -->
        <Profile name="invDetInvNumber" extends="baseReference" with="anchorTopLeft">
            <position value="11px 0px"/>
            <size value="450px 32px"/>
            <textSize value="18px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_fs25_colorMainLight"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetInvStatus" extends="baseReference" with="anchorTopLeft">
            <position value="461px 0px"/>
            <size value="360px 32px"/>
            <textSize value="16px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textAlignment value="right"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Separator after title -->
        <Profile name="invDetSepTitle" extends="baseReference" with="anchorTopLeft">
            <position value="0px -38px"/>
            <size value="832px 1px"/>
            <imageColor value="0.35 0.35 0.35 0.7"/>
        </Profile>

        <!-- From + Date -->
        <Profile name="invDetFrom" extends="baseReference" with="anchorTopLeft">
