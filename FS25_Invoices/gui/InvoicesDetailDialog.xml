<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    InvoicesDetailDialog.xml - Invoice detail view
-->
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg"/>

    <RoundCorner profile="invDetRoundBgBorder"/>
    <RoundCorner profile="invDetRoundBg"/>

    <RoundCorner profile="invDetTitleBadgeBg" id="titleBadgeBg"/>
    <ThreePartBitmap profile="invDetTitleSep"/>
    <Text profile="invDetMainTitle" text="$l10n_invoice_dialog_details" id="mainTitleText"/>

    <GuiElement profile="invDetRoot" id="dialogElement">
        <BoxLayout profile="invDetMainBox">

            <!-- Content area -->
            <GuiElement profile="invDetContentArea">

                <!-- Invoice number (left) + Status badge (right) -->
                <Text profile="invDetInvNumber" id="textTitle"/>
                <Text profile="invDetInvStatus" id="textStatus"/>

                <!-- Separator after title row -->
                <Bitmap profile="invDetSepTitle"/>

                <!-- From (left) + Date (right) -->
                <Text profile="invDetFrom" id="textFrom"/>
                <Text profile="invDetDateVal" id="textDate"/>

                <!-- To -->
                <Text profile="invDetTo" id="textTo"/>

                <!-- Separator before column headers -->
                <Bitmap profile="invDetSepHeader"/>

                <!-- Column headers: 6 columns -->
                <Text profile="invDetColDesignation" text="$l10n_invoice_detail_col_service"/>
                <Text profile="invDetColField"       text="$l10n_invoice_col_field"/>
                <Text profile="invDetColQty"         text="$l10n_invoice_detail_col_qty"/>
                <Text profile="invDetColUnit"        text="$l10n_invoice_detail_col_unit"/>
                <Text profile="invDetColUnitPrice"   text="$l10n_invoice_detail_col_unitprice"/>
                <Text profile="invDetColAmount"      text="$l10n_invoice_detail_col_amount"/>

                <!-- Accent separator (green) below headers -->
                <Bitmap profile="invDetSepAccent"/>

                <!-- Line items SmoothList -->
                <SmoothList profile="invDetList" id="listItems">
                    <ListItem profile="invDetListItem" name="templateItem">
                        <Text profile="invDetCellDesignation" name="cellDesignation"/>
                        <Text profile="invDetCellField"       name="cellField"/>
                        <Text profile="invDetCellQty"         name="cellQty"/>
                        <Text profile="invDetCellUnit"        name="cellUnit"/>
                        <Text profile="invDetCellUnitPrice"   name="cellUnitPrice"/>
                        <Text profile="invDetCellAmount"      name="cellAmount"/>
                    </ListItem>
                </SmoothList>
                <ThreePartBitmap profile="invDetSliderBox" id="sliderBox">
                    <Slider profile="fs25_listSlider" dataElementId="listItems"/>
                </ThreePartBitmap>

                <!-- Separator after list -->
                <Bitmap profile="invDetSepBottom"/>

                <!-- Notes section -->
                <Text profile="invDetNotesLabel" text="$l10n_invoice_label_note"/>
                <Text profile="invDetNotesValue" id="textNotes"/>

                <!-- Separator before total -->
                <Bitmap profile="invDetSepBeforeTotal"/>

                <!-- TOTAL bar (full width) -->
                <Bitmap profile="invDetTotalBarBg"/>
                <Text   profile="invDetTotalLabel" text="$l10n_invoice_label_total" id="textTotalLabel"/>
                <Text   profile="invDetVatInfoText" id="textVatInfo"/>
                <Text   profile="invDetTotalValue" id="textTotal"/>

            </GuiElement>
        </BoxLayout>
    </GuiElement>

    <!-- Button bar -->
    <RoundCorner profile="invDetButtonBarBg"/>
    <BoxLayout profile="invDetButtonBox" id="buttonsPC">
        <Button profile="buttonOK" text="$l10n_invoice_btn_payInvoice" onClick="onClickPay" id="btnPay"/>
        <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
        <Button profile="buttonBack" text="$l10n_invoice_btn_close" onClick="onClickBack"/>
    </BoxLayout>

    <GUIProfiles>
        <!-- Root -->
        <Profile name="invDetRoot" extends="baseReference" with="anchorMiddleCenter">
            <position value="0px -20px"/>
            <size value="800px 500px"/>
        </Profile>
        <Profile name="invDetRoundBgBorder" extends="baseReference" with="anchorMiddleCenter">
            <position value="0px 3px"/>
            <size value="806px 592px"/>
            <color value="$preset_fs25_colorGreyDark"/>
            <cornerSize value="0.5"/>
        </Profile>
        <Profile name="invDetRoundBg" extends="baseReference" with="anchorMiddleCenter">
            <position value="0px -20px"/>
            <size value="800px 540px"/>
            <color value="0.01 0.01 0.01 1.00"/>
            <cornerSize value="0.5"/>
        </Profile>
        <Profile name="invDetTitleBadgeBg" extends="baseReference" with="anchorMiddleCenter">
            <position value="0px 272px"/>
            <size value="1px 45px"/>
            <color value="$preset_fs25_colorMainHighlight"/>
            <cornerSize value="0.5"/>
        </Profile>
        <Profile name="invDetTitleSep" extends="fs25_lineSeparatorTopHighlighted" with="anchorMiddleCenter">
            <position value="0px 250px"/>
            <size value="740px 1px"/>
        </Profile>
        <Profile name="invDetMainTitle" extends="baseReference" with="anchorMiddleCenter">
            <position value="0px 272px"/>
            <size value="716px 45px"/>
            <textSize value="18px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetMainBox" extends="emptyPanel" with="anchorTopCenter">
            <size value="740px 480px"/>
            <flowDirection value="vertical"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
            <elementSpacing value="10px"/>
            <margin value="15px 0px 0px 0px"/>
        </Profile>
        <!-- Subtitle -->
        <Profile name="invDetSubTitle" extends="baseReference">
            <size value="740px 28px"/>
            <margin value="0px 0px 10px 0px"/>
            <textSize value="18px"/>
            <textBold value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <!-- Content area -->
        <Profile name="invDetContentArea" extends="emptyPanel">
            <size value="740px 478px"/>
        </Profile>

        <!-- Invoice number (left) + Status (right) -->
        <Profile name="invDetInvNumber" extends="baseReference" with="anchorTopLeft">
            <position value="10px 0px"/>
            <size value="400px 28px"/>
            <textSize value="18px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_fs25_colorMainLight"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetInvStatus" extends="baseReference" with="anchorTopLeft">
            <position value="410px 0px"/>
            <size value="320px 28px"/>
            <textSize value="16px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textAlignment value="right"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Separator after title -->
        <Profile name="invDetSepTitle" extends="baseReference" with="anchorTopLeft">
            <position value="0px -34px"/>
            <size value="740px 1px"/>
            <imageColor value="0.35 0.35 0.35 0.7"/>
        </Profile>

        <!-- From + Date -->
        <Profile name="invDetFrom" extends="baseReference" with="anchorTopLeft">
            <position value="10px -42px"/>
            <size value="350px 24px"/>
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetDateVal" extends="baseReference" with="anchorTopLeft">
            <position value="380px -42px"/>
            <size value="350px 24px"/>
            <textSize value="14px"/>
            <textBold value="false"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="right"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- To -->
        <Profile name="invDetTo" extends="baseReference" with="anchorTopLeft">
            <position value="10px -68px"/>
            <size value="350px 24px"/>
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="$preset_fs25_colorMainHighlight"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Separator before columns -->
        <Profile name="invDetSepHeader" extends="baseReference" with="anchorTopLeft">
            <position value="0px -98px"/>
            <size value="740px 1px"/>
            <imageColor value="0.35 0.35 0.35 0.7"/>
        </Profile>
        <!-- Column headers -->
        <Profile name="invDetColDesignation" extends="baseReference" with="anchorTopLeft">
            <position value="10px -104px"/>
            <size value="190px 22px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetColField" extends="baseReference" with="anchorTopLeft">
            <position value="210px -104px"/>
            <size value="78px 22px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetColQty" extends="baseReference" with="anchorTopLeft">
            <position value="293px -104px"/>
            <size value="52px 22px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetColUnit" extends="baseReference" with="anchorTopLeft">
            <position value="350px -104px"/>
            <size value="52px 22px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetColUnitPrice" extends="baseReference" with="anchorTopLeft">
            <position value="409px -104px"/>
            <size value="113px 22px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetColAmount" extends="baseReference" with="anchorTopLeft">
            <position value="530px -104px"/>
            <size value="200px 22px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="right"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Accent separator (green) -->
        <Profile name="invDetSepAccent" extends="baseReference" with="anchorTopLeft">
            <position value="0px -130px"/>
            <size value="740px 1px"/>
            <imageColor value="$preset_fs25_colorMainHighlight"/>
        </Profile>
        <!-- Line items list -->
        <Profile name="invDetList" extends="emptyPanel" with="anchorTopLeft">
            <position value="0px -136px"/>
            <size value="740px 200px"/>
        </Profile>
        <Profile name="invDetSliderBox" extends="fs25_listSliderBox" with="anchorTopLeft">
            <position value="751px -136px"/>
            <size value="6px 200px"/>
        </Profile>

        <!-- List row -->
        <Profile name="invDetListItem" extends="baseReference" with="anchorTopStretchingX alternating">
            <height value="32px"/>
            <imageColor value="$preset_fs25_colorGrey"/>
            <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
            <imageSelectedColor value="$preset_fs25_colorMainHighlight"/>
        </Profile>

        <!-- Row cells -->
        <Profile name="invDetCellDesignation" extends="baseReference">
            <position value="10px 0px"/>
            <size value="190px 32px"/>
            <textSize value="14px"/>
            <textColor value="1 1 1 1"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetCellField" extends="baseReference">
            <position value="210px 0px"/>
            <size value="78px 32px"/>
            <textSize value="12px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetCellQty" extends="baseReference">
            <position value="293px 0px"/>
            <size value="52px 32px"/>
            <textSize value="13px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetCellUnit" extends="baseReference">
            <position value="350px 0px"/>
            <size value="52px 32px"/>
            <textSize value="13px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetCellUnitPrice" extends="baseReference">
            <position value="409px 0px"/>
            <size value="113px 32px"/>
            <textSize value="13px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetCellAmount" extends="baseReference">
            <position value="530px 0px"/>
            <size value="200px 32px"/>
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="$preset_fs25_colorMainHighlight"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="right"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Separator after list -->
        <Profile name="invDetSepBottom" extends="baseReference" with="anchorTopLeft">
            <position value="0px -340px"/>
            <size value="740px 1px"/>
            <imageColor value="0.35 0.35 0.35 0.7"/>
        </Profile>
        <!-- Notes section -->
        <Profile name="invDetNotesLabel" extends="baseReference" with="anchorTopLeft">
            <position value="10px -340px"/>
            <size value="80px 36px"/>
            <textSize value="13px"/>
            <textBold value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetNotesValue" extends="baseReference" with="anchorTopLeft">
            <position value="95px -340px"/>
            <size value="635px 36px"/>
            <textSize value="13px"/>
            <textLineHeightScale value="1.3"/>
            <textColor value="$preset_fs25_colorMainLight"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Separator before total -->
        <Profile name="invDetSepBeforeTotal" extends="baseReference" with="anchorTopLeft">
            <position value="0px -376px"/>
            <size value="740px 1px"/>
            <imageColor value="0.35 0.35 0.35 0.7"/>
        </Profile>
        <!-- Total bar -->
        <Profile name="invDetTotalBarBg" extends="baseReference" with="anchorTopLeft">
            <position value="0px -384px"/>
            <size value="740px 45px"/>
            <imageColor value="0 0 0 1"/>
        </Profile>
        <Profile name="invDetTotalLabel" extends="baseReference" with="anchorTopLeft">
            <position value="20px -384px"/>
            <size value="200px 45px"/>
            <textSize value="20px"/>
            <textBold value="true"/>
            <textColor value="0.6 0.6 0.6 1"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetVatInfoText" extends="baseReference" with="anchorTopLeft">
            <position value="250px -384px"/>
            <size value="470px 18px"/>
            <textSize value="12px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="right"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="invDetTotalValue" extends="baseReference" with="anchorTopLeft">
            <position value="250px -402px"/>
            <size value="470px 27px"/>
            <textSize value="26px"/>
            <textBold value="true"/>
            <textColor value="$preset_fs25_colorMainHighlight"/>
            <textAlignment value="right"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <!-- Button bar -->
        <Profile name="invDetButtonBarBg" extends="baseReference" with="anchorMiddleCenter">
            <position value="0px -270px"/>
            <size value="800px 40px"/>
            <color value="0 0 0 1"/>
            <cornerSize value="0.5"/>
        </Profile>
        <Profile name="invDetButtonBox" extends="fs25_dialogButtonBox" with="anchorMiddleCenter">
            <position value="0px -270px"/>
            <size value="800px 40px"/>
            <imageColor value="0 0 0 0"/>
            <alignmentX value="right"/>
            <alignmentY value="middle"/>
        </Profile>
    </GUIProfiles>
</GUI>
