<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    InvoicesWizardStep2.xml - Step 2: Select work types
-->
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

    <GuiElement profile="fs25_dialogBg" id="dialogElement" size="900px 700px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>

        <GuiElement profile="fs25_dialogContentContainer">

            <BoxLayout profile="wizStep2MainBox">

                <!-- Title text (flows in BoxLayout) -->
                <Text profile="wizStep2MainTitle" text="$l10n_invoice_wizard_mainTitle" id="mainTitleText"/>

                <!-- Green gradient separator (centered dynamically) -->
                <GuiElement profile="wizStep2TitleSepWrapper">
                    <ThreePartBitmap profile="wizStep2TitleSep" id="titleSep"/>
                </GuiElement>

                <Text profile="wizStep2SubTitle" text="$l10n_invoice_wizard_step2_subtitle" id="dialogTextElement"/>

                <BoxLayout profile="wizStep2ContentBox">

                    <!-- Left column: Summary (read-only) -->
                    <GuiElement profile="wizStep2SummaryColumn">
                        <Text profile="wizStep2SummaryTitle" text="$l10n_invoice_wizard_selection_summary"/>
                        <GuiElement profile="wizStep2SummaryContentWrapper">
                            <Bitmap profile="wizStep2SummarySeparator"/>
                            <SmoothList profile="wizStep2SummaryList" id="summaryList">
                                <ListItem profile="wizStep2SummaryListItem" name="summaryTemplate">
                                    <Text profile="wizStep2SummaryCellText" name="cellText"/>
                                </ListItem>
                            </SmoothList>
                            <ThreePartBitmap profile="wizStep2SummarySliderBox" id="summarySliderBox">
                                <Slider profile="fs25_listSlider" dataElementId="summaryList"/>
                            </ThreePartBitmap>
                        </GuiElement>
                    </GuiElement>

                    <!-- Right column: Selection -->
                    <GuiElement profile="wizStep2SelectionColumn">
                        <Text profile="wizStep2SelectionTitle" text="$l10n_invoice_wizard_step2_label"/>
                        <GuiElement profile="wizStep2ListWrapper">
                            <SmoothList profile="wizStep2List" id="listWorkTypes">
                                <ListItem profile="wizStep2ListItem" name="workTypeTemplate">
                                    <Text profile="wizStep2WorkName" position="14px 0px" size="248px 32px" name="cellName"/>
                                    <Text profile="wizStep2WorkPrice" position="264px 0px" size="118px 32px" name="cellPrice"/>
                                </ListItem>
                            </SmoothList>
                            <ThreePartBitmap profile="wizStep2SliderBox">
                                <Slider profile="fs25_listSlider" dataElementId="listWorkTypes"/>
                            </ThreePartBitmap>
                        </GuiElement>
                    </GuiElement>

                </BoxLayout>

            </BoxLayout>

        </GuiElement>

        <!-- Button bar -->
        <BoxLayout profile="fs25_dialogButtonBox" size="860px 60px">
            <Button profile="wizStep2ButtonRemove" id="btnRemove" text="$l10n_invoice_btn_remove" onClick="onClickRemove" disabled="true"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="wizStep2ButtonAdd" id="btnAdd" text="$l10n_invoice_btn_add" onClick="onClickAdd" disabled="true"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="wizStep2ButtonBack" text="$l10n_invoice_btn_back" onClick="onClickBack"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="wizStep2ButtonNext" id="btnNext" text="$l10n_invoice_btn_next" onClick="onClickNext"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="wizStep2ButtonCancel" text="$l10n_invoice_btn_cancel" onClick="onClickCancel"/>
        </BoxLayout>
    </GuiElement>

    <GUIProfiles>

        <!-- Title text (BoxLayout child) -->
        <Profile name="wizStep2MainTitle" extends="baseReference">
            <size value="832px 40px"/>
            <textSize value="18px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_fs25_colorMainLight"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <!-- Separator wrapper (BoxLayout child) -->
        <Profile name="wizStep2TitleSepWrapper" extends="emptyPanel">
            <size value="832px 1px"/>
            <margin value="0px 0px 20px 0px"/>
        </Profile>
        <!-- Green gradient separator -->
        <Profile name="wizStep2TitleSep" extends="fs25_lineSeparatorTopHighlighted" with="anchorTopCenter">
            <size value="200px 1px"/>
        </Profile>

        <Profile name="wizStep2MainBox" extends="emptyPanel" with="anchorTopCenter">
            <size value="832px 630px"/>
            <flowDirection value="vertical"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
            <elementSpacing value="0px"/>
        </Profile>

        <Profile name="wizStep2SubTitle" extends="baseReference">
            <size value="832px 32px"/>
            <margin value="0px 0px 12px 0px"/>
            <textSize value="18px"/>
            <textBold value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Two-column layout -->
        <Profile name="wizStep2ContentBox" extends="emptyPanel">
            <size value="832px 525px"/>
            <flowDirection value="horizontal"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
            <elementSpacing value="11px"/>
        </Profile>

        <!-- Left column: Summary -->
        <Profile name="wizStep2SummaryColumn" extends="emptyPanel">
            <size value="411px 525px"/>
        </Profile>

        <Profile name="wizStep2SummaryTitle" extends="baseReference" with="anchorTopLeft">
            <position value="14px -22px"/>
            <size value="397px 28px"/>
            <textSize value="13px"/>
            <textBold value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <Profile name="wizStep2SummaryContentWrapper" extends="emptyPanel" with="anchorTopLeft">
            <position value="0px -70px"/>
            <size value="411px 453px"/>
        </Profile>

        <Profile name="wizStep2SummarySeparator" extends="baseReference" with="anchorTopLeft">
            <position value="0px 0px"/>
            <size value="411px 1px"/>
            <imageColor value="0.35 0.35 0.35 0.7"/>
        </Profile>

        <Profile name="wizStep2SummaryList" extends="emptyPanel" with="anchorTopLeft">
            <position value="0px -14px"/>
            <size value="394px 439px"/>
        </Profile>

        <Profile name="wizStep2SummarySliderBox" extends="fs25_listSliderBox" with="anchorTopLeft">
            <position value="406px -14px"/>
            <size value="6px 439px"/>
        </Profile>

        <Profile name="wizStep2SummaryListItem" extends="baseReference" with="anchorTopStretchingX">
            <height value="24px"/>
            <imageColor value="0 0 0 0"/>
        </Profile>

        <Profile name="wizStep2SummaryCellText" extends="baseReference">
            <position value="0px 0px"/>
            <size value="394px 24px"/>
            <imageColor value="0 0 0 0"/>
            <textSize value="15px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Right column: Selection -->
        <Profile name="wizStep2SelectionColumn" extends="emptyPanel">
            <size value="411px 525px"/>
        </Profile>

        <Profile name="wizStep2SelectionTitle" extends="baseReference" with="anchorTopLeft">
            <position value="14px -22px"/>
            <size value="397px 28px"/>
            <textSize value="13px"/>
            <textBold value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <Profile name="wizStep2ListWrapper" extends="emptyPanel" with="anchorTopLeft">
            <position value="0px -70px"/>
            <size value="411px 453px"/>
        </Profile>

        <Profile name="wizStep2List" extends="emptyPanel">
            <size value="411px 453px"/>
            <position value="0px 0px"/>
        </Profile>

        <Profile name="wizStep2SliderBox" extends="fs25_listSliderBox" with="anchorTopLeft">
            <size value="6px 453px"/>
            <position value="418px 0px"/>
        </Profile>

        <Profile name="wizStep2ListItem" extends="baseReference" with="anchorTopStretchingX alternating">
            <height value="32px"/>
            <imageColor value="$preset_fs25_colorGrey"/>
            <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
            <imageSelectedColor value="$preset_fs25_colorMainHighlight"/>
        </Profile>

        <Profile name="wizStep2WorkName" extends="baseReference" with="anchorStretchingYLeft">
            <textSize value="15px"/>
            <textColor value="1 1 1 1"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <Profile name="wizStep2WorkPrice" extends="baseReference" with="anchorStretchingYLeft">
            <textSize value="13px"/>
            <textColor value="$preset_fs25_colorMainHighlight"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="right"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Button profiles -->
        <Profile name="wizStep2ButtonBack" extends="buttonOK">
            <inputAction value="MENU_PAGE_PREV"/>
        </Profile>

        <Profile name="wizStep2ButtonRemove" extends="buttonOK">
            <inputAction value="MENU_CANCEL"/>
        </Profile>

        <Profile name="wizStep2ButtonAdd" extends="buttonOK">
            <inputAction value="MENU_ACTIVATE"/>
        </Profile>

        <Profile name="wizStep2ButtonNext" extends="buttonOK">
            <inputAction value="MENU_PAGE_NEXT"/>
        </Profile>

        <Profile name="wizStep2ButtonCancel" extends="buttonBack">
            <inputAction value="MENU_BACK"/>
        </Profile>
    </GUIProfiles>
</GUI>
