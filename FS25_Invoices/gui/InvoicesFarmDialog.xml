<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    InvoicesFarmDialog.xml - Farm selection dialog
-->
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer" />
    <Bitmap profile="dialogFullscreenBg"/>

    <GuiElement profile="invSelectFieldDialog" id="dialogElement">
        <GuiElement profile="fs25_dialogContentContainer">
            <BoxLayout profile="invSelectMainBox">
                <Text profile="fs25_dialogTitle" id="dialogTitle" text="$l10n_invoice_btn_selectFarm"/>
                
                <!-- List section -->
                <GuiElement profile="invSelectListSection">
                    <GuiElement profile="invSelectHeader">
                        <Text profile="invSelectHeaderCell" position="0px 0px" size="500px 40px" text="$l10n_invoice_col_farm"/>
                    </GuiElement>
                    <SmoothList profile="invSelectList" id="listFarms" position="0px 45px">
                        <ListItem profile="invSelectListItem" name="farmTemplate">
                            <Text profile="invTableCellCenter" position="0px 0px" size="500px 40px" name="cellName" />
                        </ListItem>
                    </SmoothList>
                    <ThreePartBitmap profile="fs25_listSliderBox" size="6px 600px" position="510px 45px">
                        <Slider profile="fs25_listSlider" size="6px 590px" dataElementId="listFarms" />
                    </ThreePartBitmap>
                </GuiElement>
            </BoxLayout>
        </GuiElement>
        
        <BoxLayout profile="fs25_dialogButtonBox" id="buttonsPC">
            <Button profile="buttonBack" text="$l10n_invoice_btn_cancel" onClick="onClickBack" />
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="buttonOK" id="btnSelect" text="$l10n_invoice_btn_select" onClick="onClickSelect" />
        </BoxLayout>
    </GuiElement>
</GUI>
