<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    InvoicesMainDashboard.xml - Consolidated invoice creation dashboard
-->
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

    <GuiElement profile="fs25_dialogBg" id="dialogElement" size="910px 1040px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>

        <GuiElement profile="fs25_dialogContentContainer">
            <BoxLayout profile="dashMainBox">

                <!-- Title -->
                <Text profile="dashMainTitle" text="$l10n_invoice_wizard_mainTitle" id="mainTitleText"/>
                <GuiElement profile="dashTitleSepWrapper">
                    <ThreePartBitmap profile="dashTitleSep" id="titleSep"/>
                </GuiElement>
                <GuiElement profile="dashTitleSpacer"/>

                <!-- Content area (absolute positioning) -->
                <GuiElement profile="dashContentArea">

                    <!-- Background behind top 3 selection tables -->
                    <RoundCorner profile="dashSelectionBg"/>

                    <!-- ==================== SELECTION ZONE ==================== -->

                    <GuiElement profile="dashSelectionZone">

                        <!-- Column 1: Client -->
                        <Text profile="dashColLabel" position="10px -8px" text="$l10n_invoice_wizard_step1_label"/>
                        <GuiElement profile="dashColWrapper" position="8px -36px" size="268px 336px">
                            <SmoothList profile="dashColList" id="listFarms" onClick="onFarmListClicked">
                                <ListItem profile="dashSelectListItemFlat" name="farmTemplate">
                                    <Text profile="dashCellBrackets" text="[   ]"/>
                                    <Text profile="dashCellCheck" name="cellTick" text=" X "/>
                                    <Text profile="dashFarmCellName" name="cellName"/>
                                </ListItem>
                            </SmoothList>
                            <ThreePartBitmap profile="dashSliderBox" position="259px 0px" size="6px 336px" id="farmSliderBox">
                                <Slider profile="fs25_listSlider" size="6px 336px" dataElementId="listFarms"/>
                            </ThreePartBitmap>
                        </GuiElement>

                        <!-- Column 2: Work types (locked until client selected) -->
                        <Text profile="dashColLabel" position="288px -8px" text="$l10n_invoice_wizard_step2_label"/>
                        <GuiElement profile="dashColWrapper" position="286px -36px" size="268px 336px" id="workTypesZone">
                            <SmoothList profile="dashColList" id="listWorkTypes" onClick="onWorkTypeListClicked">
                                <ListItem profile="dashSelectListItemFlat" name="workTypeTemplate">
                                    <Text profile="dashCellBrackets" text="[   ]"/>
                                    <Text profile="dashCellCheck" name="cellTick" text=" X "/>
                                    <Text profile="dashWorkCellName" name="cellName"/>
                                    <Text profile="dashWorkCellPrice" name="cellPrice"/>
                                </ListItem>
                            </SmoothList>
                            <ThreePartBitmap profile="dashSliderBox" position="259px 0px" size="6px 336px" id="workSliderBox">
                                <Slider profile="fs25_listSlider" size="6px 336px" dataElementId="listWorkTypes"/>
                            </ThreePartBitmap>
                        </GuiElement>

                        <!-- Column 3: Fields (always visible) -->
                        <Text profile="dashColLabel" position="566px -8px" text="$l10n_invoice_wizard_step3_label"/>
                        <GuiElement profile="dashColWrapper" position="564px -36px" size="268px 336px" id="fieldsPanel">
                            <SmoothList profile="dashColList" id="listFields" listSectionHeader="section" onClick="onFieldListClicked">
                                <ListItem profile="dashSelectListItemFlat" name="fieldTemplate">
                                    <Text profile="dashCellBrackets" text="[   ]"/>
                                    <Text profile="dashCellCheck" name="cellTick" text=" X "/>
                                    <Text profile="dashColFieldCellName" name="cellName"/>
                                    <Text profile="dashColFieldCellArea" name="cellArea"/>
                                </ListItem>
                                <ListItem profile="dashSectionHeader" name="section">
                                    <Text profile="dashSectionTitle" name="title"/>
                                </ListItem>
                            </SmoothList>
                            <ThreePartBitmap profile="dashSliderBox" position="259px 0px" size="6px 336px" id="fieldSliderBox">
                                <Slider profile="fs25_listSlider" size="6px 336px" dataElementId="listFields"/>
                            </ThreePartBitmap>
                            <Text profile="dashFieldsEmptyText" id="fieldsEmptyText" text="$l10n_invoice_dash_no_fields"/>
                        </GuiElement>
                    </GuiElement>

                    <!-- ==================== RECAP ZONE ==================== -->

                    <!-- Header: From / To -->
                    <Text profile="dashHeaderFrom" id="textFrom"/>
                    <Text profile="dashHeaderTo"   id="textTo"/>
                    <Bitmap profile="dashSepTop"/>

                    <!-- Column headers -->
                    <Text profile="dashColDesignation" text="$l10n_invoice_step4_col_service"/>
                    <Text profile="dashColField"       text="$l10n_invoice_col_field"/>
                    <Text profile="dashColQty"         text="$l10n_invoice_step4_col_qty"/>
                    <Text profile="dashColUnit"        text="$l10n_invoice_detail_col_unit"/>
                    <Text profile="dashColPrice"       text="$l10n_invoice_step4_col_unitprice"/>
                    <Text profile="dashColVat"         text="$l10n_invoice_step4_col_vat"/>
                    <Text profile="dashColAmount"      text="$l10n_invoice_step4_col_amount"/>
                    <Bitmap profile="dashSepHeaders"/>

                    <!-- Line items list (full width, slider outside like Detail dialog) -->
                    <SmoothList profile="dashItemList" id="listItems">
                        <ListItem profile="dashItemListRow" name="itemTemplate">
                            <ThreePartBitmap profile="dashItemGradient" name="alternating"/>
                            <Bitmap profile="dashCellItemIcon" name="cellIcon"/>
                            <Text profile="dashCellDesignation" name="cellDesignation"/>
                            <Text profile="dashCellField"       name="cellField"/>
                            <Text profile="dashCellQty"         name="cellQty"/>
                            <Text profile="dashCellUnit"        name="cellUnit"/>
                            <Text profile="dashCellPrice"       name="cellPrice"/>
                            <Text profile="dashCellVat"         name="cellVat"/>
                            <Text profile="dashCellAmount"      name="cellAmount"/>
                        </ListItem>
                    </SmoothList>
                    <ThreePartBitmap profile="dashRecapSliderBox" id="itemSliderBox">
                        <Slider profile="fs25_listSlider" dataElementId="listItems"/>
                    </ThreePartBitmap>

                    <!-- Footer: Note | P.U. | Qty | TVA % -->
                    <Text      profile="dashFooterNoteLabel"  text="$l10n_invoice_label_note"/>
                    <TextInput profile="dashFooterNoteInput"  id="inputNote" enterWhenClickOutside="false">
                        <ThreePartBitmap profile="dashOutlineBg" absoluteSizeOffset="0px 0px"/>
                        <ThreePartBitmap profile="dashInputIconBox">
                            <Bitmap profile="dashInputIcon"/>
                        </ThreePartBitmap>
                        <Text profile="dashNotePlaceholder" name="notePlaceholder" text="$l10n_invoice_placeholder_note"/>
                    </TextInput>

                    <Text      profile="dashFooterPriceLabel" text="$l10n_invoice_step4_col_unitprice"/>
                    <TextInput profile="dashFooterPriceInput" id="inputPrice" onTextChanged="onPriceTextChanged" enterWhenClickOutside="false">
                        <ThreePartBitmap profile="dashOutlineBg" absoluteSizeOffset="0px 0px"/>
                        <ThreePartBitmap profile="dashInputIconBox">
                            <Bitmap profile="dashInputIcon"/>
                        </ThreePartBitmap>
                    </TextInput>

                    <Text      profile="dashFooterQtyLabel"   text="$l10n_invoice_step4_col_qty"/>
                    <TextInput profile="dashFooterQtyInput"   id="inputQty" onTextChanged="onQtyTextChanged" enterWhenClickOutside="false">
                        <ThreePartBitmap profile="dashOutlineBg" absoluteSizeOffset="0px 0px"/>
                        <ThreePartBitmap profile="dashInputIconBox">
                            <Bitmap profile="dashInputIcon"/>
                        </ThreePartBitmap>
                    </TextInput>

                    <Text      profile="dashFooterVatLabel"   text="$l10n_invoice_step4_col_vat"/>
                    <TextInput profile="dashFooterVatInput"   id="inputVat" onTextChanged="onVatRateTextChanged" enterWhenClickOutside="false">
                        <ThreePartBitmap profile="dashOutlineBg" absoluteSizeOffset="0px 0px"/>
                        <ThreePartBitmap profile="dashInputIconBox">
                            <Bitmap profile="dashInputIcon"/>
                        </ThreePartBitmap>
                    </TextInput>

                    <!-- TOTAL section -->
                    <RoundCorner profile="dashTotalBarBg"/>
                    <Text      profile="dashTotalLabel"  text="$l10n_invoice_step4_total"/>
                    <BoxLayout profile="dashTotalRightColumn" id="totalRightColumn">
                        <Text      profile="dashVatHtText"   id="textVatHt"/>
                        <Text      profile="dashVatTvaText"  id="textVatTva"/>
                        <BoxLayout profile="dashTotalSepBox">
                            <Bitmap profile="dashTotalSepLine" id="totalSep"/>
                        </BoxLayout>
                        <BoxLayout profile="dashTotalValueRow" id="totalValueRow">
                            <BoxLayout profile="dashTotalValueAnchor" id="totalValueAnchor">
                                <Text      profile="dashTotalValue"  id="textTotal"/>
                            </BoxLayout>
                        </BoxLayout>
                    </BoxLayout>

                </GuiElement>

            </BoxLayout>
        </GuiElement>

        <!-- Button bar -->
        <BoxLayout profile="fs25_dialogButtonBox" size="870px 60px">
            <Button profile="buttonOK" id="btnSend" text="$l10n_invoice_btn_sendInvoice" onClick="onClickSend" disabled="true"/>
            <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
            <Button profile="dashBtnCancel" text="$l10n_invoice_btn_cancel" onClick="onClickCancel"/>
        </BoxLayout>
    </GuiElement>

    <GUIProfiles>

        <!-- ==================== LAYOUT ==================== -->

        <Profile name="dashMainBox" extends="emptyPanel" with="anchorTopCenter">
