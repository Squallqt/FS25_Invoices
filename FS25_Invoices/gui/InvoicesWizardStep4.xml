        </Profile>
        <Profile name="wizStep4ColQty" extends="baseReference" with="anchorTopLeft">
            <position value="293px -44px"/>
            <size value="52px 24px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4ColUnit" extends="baseReference" with="anchorTopLeft">
