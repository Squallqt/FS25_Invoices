            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4TotalValue" extends="baseReference" with="anchorTopLeft">
            <position value="400px -376px"/>
            <size value="320px 50px"/>
            <textSize value="28px"/>
            <textBold value="true"/>
            <textColor value="$preset_fs25_colorMainHighlight"/>
            <textAlignment value="right"/>
