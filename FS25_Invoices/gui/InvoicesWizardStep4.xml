<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    InvoicesWizardStep4.xml - Step 4: Invoice recap
-->
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg"/>

    <RoundCorner profile="wizStep4RoundBgBorder"/>
    <RoundCorner profile="wizStep4RoundBg"/>

    <RoundCorner profile="wizStep4TitleBadgeBg" id="titleBadgeBg"/>
    <ThreePartBitmap profile="wizStep4TitleSep"/>
    <Text profile="wizStep4MainTitle" text="$l10n_invoice_wizard_mainTitle" id="mainTitleText"/>

    <GuiElement profile="wizStep4Root" id="dialogElement">
        <BoxLayout profile="wizStep4MainBox">
            <Text profile="wizStep4SubTitle" text="$l10n_invoice_wizard_step4_subtitle" id="dialogTextElement"/>

            <!-- ======= Content area (absolute positioning) ======= -->
            <GuiElement profile="wizStep4ContentArea">

                <!-- Header: From / To -->
                <Text profile="wizStep4HeaderFrom" id="textFrom"/>
                <Text profile="wizStep4HeaderTo"   id="textTo"/>

                <!-- Separator -->
                <Bitmap profile="wizStep4SepTop"/>

                <!-- Column headers (6 columns) -->
                <Text profile="wizStep4ColDesignation" text="$l10n_invoice_step4_col_service"/>
                <Text profile="wizStep4ColField"       text="$l10n_invoice_col_field"/>
                <Text profile="wizStep4ColQty"         text="$l10n_invoice_step4_col_qty"/>
                <Text profile="wizStep4ColUnit"        text="$l10n_invoice_detail_col_unit"/>
                <Text profile="wizStep4ColPrice"       text="$l10n_invoice_step4_col_unitprice"/>
                <Text profile="wizStep4ColAmount"      text="$l10n_invoice_step4_col_amount"/>

                <!-- Accent separator below headers -->
                <Bitmap profile="wizStep4SepHeaders"/>

                <!-- Line items SmoothList (6 columns) -->
                <SmoothList profile="wizStep4List" id="listItems">
                    <ListItem profile="wizStep4ListItem" name="itemTemplate">
                        <Text profile="wizStep4CellDesignation" name="cellDesignation"/>
                        <Text profile="wizStep4CellField"       name="cellField"/>
                        <Text profile="wizStep4CellQty"         name="cellQty"/>
                        <Text profile="wizStep4CellUnit"        name="cellUnit"/>
                        <Text profile="wizStep4CellPrice"       name="cellPrice"/>
                        <Text profile="wizStep4CellAmount"      name="cellAmount"/>
                    </ListItem>
                </SmoothList>
                <ThreePartBitmap profile="wizStep4SliderBox" id="sliderBox">
                    <Slider profile="fs25_listSlider" dataElementId="listItems"/>
                </ThreePartBitmap>

                <!-- Separator after list -->
                <Bitmap profile="wizStep4SepList"/>

                <!-- Footer: Note (left) | Unit Price (center) | Qty (right) -->
                <Text      profile="wizStep4FooterNoteLabel"  text="$l10n_invoice_label_note"/>
                <TextInput profile="wizStep4FooterNoteInput" id="inputNote" textAlignment="center">
                    <ThreePartBitmap profile="fs25_textInputBg" absoluteSizeOffset="0px 0px"/>
                </TextInput>

                <Text      profile="wizStep4FooterPriceLabel" text="$l10n_invoice_step4_col_unitprice"/>
                <TextInput profile="wizStep4FooterPriceInput" id="inputPrice" onTextChanged="onPriceTextChanged" textAlignment="center">
                    <ThreePartBitmap profile="fs25_textInputBg" absoluteSizeOffset="0px 0px"/>
                </TextInput>

                <Text      profile="wizStep4FooterQtyLabel"   text="$l10n_invoice_step4_col_qty"/>
                <TextInput profile="wizStep4FooterQtyInput"   id="inputQty" onTextChanged="onQtyTextChanged" textAlignment="center">
                    <ThreePartBitmap profile="fs25_textInputBg" absoluteSizeOffset="0px 0px"/>
                </TextInput>

                <!-- TOTAL bar (full width) -->
                <Bitmap profile="wizStep4TotalBarBg"/>
                <Text   profile="wizStep4TotalLabel" text="$l10n_invoice_step4_total"/>
                <Text   profile="wizStep4TotalValue" id="textTotal"/>

            </GuiElement>
        </BoxLayout>
    </GuiElement>

    <!-- Button bar -->
    <RoundCorner profile="wizStep4ButtonBarBg"/>
    <BoxLayout profile="wizStep4ButtonBox" id="buttonsPC">
        <Button profile="buttonOK" id="btnSend" text="$l10n_invoice_btn_sendInvoice" onClick="onClickSend"/>
        <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
        <Button profile="wizStep4ButtonBack" text="$l10n_invoice_btn_back" onClick="onClickBack"/>
    </BoxLayout>

    <GUIProfiles>
        <!-- Root / backdrop                                               -->
        <Profile name="wizStep4Root" extends="baseReference" with="anchorMiddleCenter">
            <position value="0px -20px"/>
            <size value="800px 500px"/>
        </Profile>
        <Profile name="wizStep4RoundBgBorder" extends="baseReference" with="anchorMiddleCenter">
            <position value="0px 3px"/>
            <size value="806px 592px"/>
            <color value="$preset_fs25_colorGreyDark"/>
            <cornerSize value="0.5"/>
        </Profile>
        <Profile name="wizStep4RoundBg" extends="baseReference" with="anchorMiddleCenter">
            <position value="0px -20px"/>
            <size value="800px 540px"/>
            <color value="0.01 0.01 0.01 1.00"/>
            <cornerSize value="0.5"/>
        </Profile>
        <Profile name="wizStep4TitleBadgeBg" extends="baseReference" with="anchorMiddleCenter">
            <position value="0px 272px"/>
            <size value="1px 45px"/>
            <color value="$preset_fs25_colorMainHighlight"/>
            <cornerSize value="0.5"/>
        </Profile>
        <Profile name="wizStep4TitleSep" extends="fs25_lineSeparatorTopHighlighted" with="anchorMiddleCenter">
            <position value="0px 250px"/>
            <size value="740px 1px"/>
        </Profile>
        <Profile name="wizStep4MainTitle" extends="baseReference" with="anchorMiddleCenter">
            <position value="0px 272px"/>
            <size value="716px 45px"/>
            <textSize value="18px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4MainBox" extends="emptyPanel" with="anchorTopCenter">
            <size value="740px 500px"/>
            <flowDirection value="vertical"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
            <elementSpacing value="10px"/>
            <margin value="15px 0px 0px 0px"/>
        </Profile>
        <!-- Subtitle                                                      -->
        <Profile name="wizStep4SubTitle" extends="baseReference">
            <size value="740px 28px"/>
            <margin value="0px 0px 10px 0px"/>
            <textSize value="18px"/>
            <textBold value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <!-- Content area (single column, absolute children)               -->
        <Profile name="wizStep4ContentArea" extends="emptyPanel">
            <size value="740px 440px"/>
        </Profile>

        <!-- Header: From / To -->
        <Profile name="wizStep4HeaderFrom" extends="baseReference" with="anchorTopLeft">
            <position value="10px 0px"/>
            <size value="350px 26px"/>
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4HeaderTo" extends="baseReference" with="anchorTopLeft">
            <position value="380px 0px"/>
            <size value="350px 26px"/>
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="$preset_fs25_colorMainHighlight"/>
            <textAlignment value="right"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Separator -->
        <Profile name="wizStep4SepTop" extends="baseReference" with="anchorTopLeft">
            <position value="0px -34px"/>
            <size value="740px 1px"/>
            <imageColor value="0.35 0.35 0.35 0.7"/>
        </Profile>

        <!-- Column headers (6 columns) -->
        <Profile name="wizStep4ColDesignation" extends="baseReference" with="anchorTopLeft">
            <position value="10px -44px"/>
            <size value="190px 24px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4ColField" extends="baseReference" with="anchorTopLeft">
