        </Profile>

        <Profile name="wizStep4ButtonBarBg" extends="baseReference" with="anchorMiddleCenter">
            <position value="0px -270px"/>
            <size value="800px 40px"/>
            <color value="0 0 0 1"/>
            <cornerSize value="0.5"/>
        </Profile>
        <Profile name="wizStep4ButtonBox" extends="fs25_dialogButtonBox" with="anchorMiddleCenter">
            <position value="0px -270px"/>
            <imageColor value="0 0 0 0"/>
            <size value="800px 40px"/>
            <alignmentX value="right"/>
            <alignmentY value="middle"/>
        </Profile>
        <Profile name="wizStep4ButtonBack" extends="buttonOK">
            <inputAction value="MENU_PAGE_PREV"/>
        </Profile>
    </GUIProfiles>
</GUI>
