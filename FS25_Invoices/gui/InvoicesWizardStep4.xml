            <size value="52px 24px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4ColPrice" extends="baseReference" with="anchorTopLeft">
            <position value="409px -44px"/>
            <size value="113px 24px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4ColAmount" extends="baseReference" with="anchorTopLeft">
            <position value="530px -44px"/>
            <size value="200px 24px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="right"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Accent separator (green) -->
        <Profile name="wizStep4SepHeaders" extends="baseReference" with="anchorTopLeft">
            <position value="0px -74px"/>
            <size value="740px 1px"/>
            <imageColor value="$preset_fs25_colorMainHighlight"/>
        </Profile>

        <!-- Line items SmoothList  -->
        <Profile name="wizStep4List" extends="emptyPanel" with="anchorTopLeft">
            <position value="0px -82px"/>
            <size value="740px 220px"/>
        </Profile>
        <Profile name="wizStep4SliderBox" extends="fs25_listSliderBox" with="anchorTopLeft">
            <position value="751px -82px"/>
            <size value="6px 220px"/>
        </Profile>

        <!-- List row (6 columns) -->
        <Profile name="wizStep4ListItem" extends="baseReference" with="anchorTopStretchingX alternating">
            <height value="32px"/>
            <imageColor value="$preset_fs25_colorGrey"/>
            <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
            <imageSelectedColor value="$preset_fs25_colorMainHighlight"/>
        </Profile>
        <Profile name="wizStep4CellDesignation" extends="baseReference">
            <position value="10px 0px"/>
            <size value="190px 32px"/>
            <textSize value="14px"/>
            <textColor value="1 1 1 1"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4CellField" extends="baseReference">
            <position value="210px 0px"/>
            <size value="78px 32px"/>
            <textSize value="13px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4CellQty" extends="baseReference">
            <position value="293px 0px"/>
            <size value="52px 32px"/>
            <textSize value="13px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4CellUnit" extends="baseReference">
            <position value="350px 0px"/>
            <size value="52px 32px"/>
            <textSize value="13px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4CellPrice" extends="baseReference">
            <position value="409px 0px"/>
            <size value="113px 32px"/>
            <textSize value="13px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4CellAmount" extends="baseReference">
            <position value="530px 0px"/>
            <size value="200px 32px"/>
            <textSize value="14px"/>
            <textBold value="true"/>
            <textColor value="$preset_fs25_colorMainHighlight"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textAlignment value="right"/>
            <textVerticalAlignment value="middle"/>
        </Profile>

        <!-- Separator after list -->
        <Profile name="wizStep4SepList" extends="baseReference" with="anchorTopLeft">
            <position value="0px -308px"/>
            <size value="740px 1px"/>
            <imageColor value="0.35 0.35 0.35 0.7"/>
        </Profile>

        <!-- Footer: Note (0-220px) -->
        <Profile name="wizStep4FooterNoteLabel" extends="baseReference" with="anchorTopLeft">
            <position value="0px -316px"/>
            <size value="220px 18px"/>
            <textSize value="12px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4FooterNoteInput" extends="fs25_textInput" with="anchorTopLeft">
            <position value="0px -336px"/>
            <size value="220px 28px"/>
            <textAlignment value="center"/>
            <textOffset value="0px 3px"/>
        </Profile>
        <Profile name="wizStep4FooterPriceLabel" extends="baseReference" with="anchorTopLeft">
            <position value="260px -316px"/>
            <size value="220px 18px"/>
            <textSize value="12px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4FooterPriceInput" extends="fs25_textInput" with="anchorTopLeft">
            <position value="260px -336px"/>
            <size value="220px 28px"/>
            <textAlignment value="center"/>
            <textOffset value="0px 3px"/>
        </Profile>

        <!-- Footer: Quantity (520-740px) -->
        <Profile name="wizStep4FooterQtyLabel" extends="baseReference" with="anchorTopLeft">
            <position value="520px -316px"/>
            <size value="220px 18px"/>
            <textSize value="12px"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
        </Profile>
        <Profile name="wizStep4FooterQtyInput" extends="fs25_textInput" with="anchorTopLeft">
            <position value="520px -336px"/>
            <size value="220px 28px"/>
            <textAlignment value="center"/>
            <textOffset value="0px 3px"/>
        </Profile>

        <Profile name="wizStep4TotalBarBg" extends="baseReference" with="anchorTopLeft">
            <position value="0px -376px"/>
            <size value="740px 50px"/>
            <imageColor value="0 0 0 1"/>
        </Profile>
        <Profile name="wizStep4TotalLabel" extends="baseReference" with="anchorTopLeft">
            <position value="20px -376px"/>
            <size value="200px 50px"/>
            <textSize value="22px"/>
            <textBold value="true"/>
            <textColor value="0.6 0.6 0.6 1"/>
